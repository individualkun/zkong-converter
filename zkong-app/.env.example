# ============================================================
# API settings
# ============================================================
# generic: API_ENDPOINTへそのまま送信
# zkong: ZKONG APIへログインして送信
API_PROVIDER=generic

# generic API用。API_PROVIDER=generic の場合だけ使います。
API_ENDPOINT=
API_TOKEN=

# true の場合はAPI送信せず、解析と履歴出力だけ行います。
DRY_RUN=true

# ============================================================
# ZKONG settings
# ============================================================
ZKONG_BASE_URL=https://esl-jp.zkong.com
ZKONG_ACCOUNT=
ZKONG_PASSWORD=
ZKONG_STORE_ID=
ZKONG_MERCHANT_ID=
ZKONG_AGENCY_ID=
ZKONG_ATTR_CATEGORY=default
ZKONG_ATTR_NAME=default

# ============================================================
# Layout settings
# ============================================================
FORMAT_CONFIG=format/formats.json

# ============================================================
# Folder settings
# ============================================================
WAITING_DIR=data/waiting
ACTIVE_DIR=data/active
DONE_DIR=data/done
ERROR_DIR=data/error
HISTORY_DIR=data/history

# ============================================================
# Runtime settings
# ============================================================
SAVE_HISTORY_JSONL=true
FILE_STABLE_SECONDS=1.0

# ============================================================
# Cleanup settings
# ============================================================
DONE_RETENTION_DAYS=7
ERROR_RETENTION_DAYS=30
HISTORY_RETENTION_DAYS=30
MAX_DONE_FILES=100
MAX_ERROR_FILES=100
MAX_HISTORY_FILES=100
