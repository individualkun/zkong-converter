# ============================================================
# API settings
# ============================================================
# 送信先APIのベースURL。
# 例: https://example.com/api
API_ENDPOINT=

# API認証トークン。空の場合、Authorizationヘッダーは付けません。
API_TOKEN=

# true の場合はAPI送信せず、解析と履歴出力だけ行います。
DRY_RUN=true

# ============================================================
# Layout settings
# ============================================================
# ファイル種類、列番号、送信項目などを定義するJSON。
FORMAT_CONFIG=format/formats.json

# ============================================================
# Folder settings
# ============================================================
WAITING_DIR=data/waiting
ACTIVE_DIR=data/active
DONE_DIR=data/done
ERROR_DIR=data/error
HISTORY_DIR=data/history

# ============================================================
# Runtime settings
# ============================================================
# true の場合、APIへ送るpayloadを履歴JSONに保存します。
SAVE_HISTORY_JSONL=true

# コピー途中のファイルを読まないよう、サイズが安定するまで待つ秒数。
FILE_STABLE_SECONDS=1.0

# ============================================================
# Cleanup settings
# ============================================================
# done/error/history が増え続けないよう、起動時に古いファイルを削除します。
# *_RETENTION_DAYS は保存日数です。-1 にすると日数による削除をしません。
# MAX_*_FILES は残す最大件数です。0 にすると件数による削除をしません。
DONE_RETENTION_DAYS=7
ERROR_RETENTION_DAYS=30
HISTORY_RETENTION_DAYS=30
MAX_DONE_FILES=100
MAX_ERROR_FILES=100
MAX_HISTORY_FILES=100
