# ==========================================
# アプリケーション基本設定
# ==========================================
# 解析ルールの定義ファイル（JSON）のパス
FORMAT_DEF_PATH=format/formats.json

# 処理済みデータを CSV 履歴として保存するか (true / false)
SAVE_HISTORY_CSV=true

# ==========================================
# 外部システム連携（API）設定
# ==========================================
# データを送信する先のAPIエンドポイント（空の場合は送信スキップ）
# 例: http://192.168.1.100:8080/api/receive
API_ENDPOINT=

# ==========================================
# フォルダ監視設定 (オプション)
# ==========================================
# 監視対象などのベースディレクトリ名（通常は変更不要）
WAITING_DIR=data/waiting
ACTIVE_DIR=data/active
PROCESSED_DIR=data/processed
HISTORY_DIR=data/history